#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"

if [ ! -d "$VENV_DIR" ]; then
    echo "Error: Virtual environment not found."
    echo "Run './setup.sh' first to initialize."
    exit 1
fi

source "$VENV_DIR/bin/activate"

echo "Running music organizer..."
python3 "$SCRIPT_DIR/organize.py" "$@"

# Check if --live was used to decide on cleanup
if [[ "$*" == *"--live"* ]]; then
    # Find the source path (first non-flag argument)
    SOURCE_PATH=""
    for arg in "$@"; do
        if [[ "$arg" != --* ]]; then
            SOURCE_PATH="$arg"
            break
        fi
    done

    # Only clean up if --move or in-place (no destination)
    # If --copy was used with a destination, we don't want to delete the source
    if [ -n "$SOURCE_PATH" ] && [ -d "$SOURCE_PATH" ]; then
        IS_MOVE=false
        if [[ "$*" == *"--move"* ]]; then
            IS_MOVE=true
        elif [[ -z "$SOURCE_PATH" || "$SOURCE_PATH" == "$1" ]]; then 
            # If no destination provided, it's in-place move
            IS_MOVE=true
        fi
        
        # If no destination was provided, it's always a move
        # If --move flag was provided, it's a move
        if [[ "$*" == *"--move"* ]] || [[ -z "$1" || "$1" == "$SOURCE_PATH" && -z "$2" ]]; then
             # Wait, let's just check if --move or no destination
             # Actually, if --copy is present, we skip cleanup
             if [[ "$*" != *"--copy"* ]]; then
                 echo ""
                 echo "Cleaning up empty directories in source: $SOURCE_PATH"
                 find "$(realpath "$SOURCE_PATH")" -type d -empty -delete
                 echo "Cleanup complete."
             else
                 echo ""
                 echo "Skipping cleanup (COPY mode was used)."
             fi
        fi
    fi
fi

